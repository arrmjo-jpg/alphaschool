APP_NAME=AlphaSchool
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker development environment (docs/developer/docker-development.md) --
# every host below is a Compose service name on the shared network, never
# 127.0.0.1/localhost. This file is what `cp .env.example .env` produces
# by default, so a fresh clone is Docker-correct with zero manual editing.
DB_CONNECTION=mariadb
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=alphaschool
DB_USERNAME=alphaschool
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Admin Platform Foundation (ADR-0015) -- comma-separated origins allowed
# to call the API from a browser (the Vite dev server by default). This
# one is deliberately a host-machine browser origin, not a Docker service
# host -- the browser runs outside the network, on the developer's own
# machine, reaching the Vite container via its published port.
CORS_ALLOWED_ORIGINS=http://localhost:5173

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@alphaschool.test"
MAIL_FROM_NAME="${APP_NAME}"

# Meilisearch (docs/DOMAIN_BLUEPRINT.md's "abstract now, pick the search
# backend later" decision) -- provisioned per the Docker infra milestone
# ahead of laravel/scout actually being installed; inert until then.
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
